{
  "name": "fda-watch",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "fda-watch app",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "pip install -e '.[dev]'",
  "postStartCommand": "uvicorn api.main:app --host 0.0.0.0 --port 8000",
  "remoteEnv": {
    "CORS_ORIGINS": "*"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
